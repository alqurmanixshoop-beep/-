<!-- بداية كود قسم الذكاء الاصطناعي والبوابة الفخمة - القرماني إكس AQX -->
<style>
@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@500;700;800&display=swap');

/* تنسيقات الأداة الرئيسية (الأقسام) */
.qarmani-ai-widget {
    font-family: 'Tajawal', sans-serif;
    direction: rtl;
    background: #ffffff;
    padding: 40px 25px;
    border-radius: 24px;
    box-shadow: 0 15px 50px rgba(99, 102, 241, 0.08);
    max-width: 100%;
    margin: 20px auto;
    border: 1px solid #f1f0f7;
}

.qarmani-ai-title {
    text-align: center;
    font-size: 30px;
    font-weight: 800;
    color: #4f46e5;
    margin-bottom: 45px;
    position: relative;
    display: block;
    text-shadow: 0 2px 4px rgba(79, 70, 229, 0.1);
}

.qarmani-ai-title::after {
    content: '';
    width: 100px;
    height: 6px;
    background: linear-gradient(90deg, #818cf8, #c084fc, #e879f9);
    display: block;
    margin: 15px auto 0;
    border-radius: 10px;
    box-shadow: 0 4px 15px rgba(192, 132, 252, 0.4);
}

.qarmani-ai-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
}

.qarmani-ai-node {
    display: flex;
    align-items: center;
    padding: 18px 16px;
    background: #f8fafc;
    border: 2px solid #e2e8f0;
    border-radius: 16px;
    text-decoration: none;
    color: #1e293b;
    transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
    cursor: pointer;
    position: relative;
    overflow: hidden;
    z-index: 1;
}

.qarmani-ai-node::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(129, 140, 248, 0.08) 0%, rgba(192, 132, 252, 0.12) 100%);
    z-index: -1;
    opacity: 0;
    transition: opacity 0.4s ease;
}

.qarmani-ai-node:hover {
    background: #ffffff;
    border-color: #a855f7;
    transform: translateY(-6px);
    box-shadow: 0 15px 25px rgba(168, 85, 247, 0.15);
}

.qarmani-ai-node:hover::before {
    opacity: 1;
}

.qarmani-ai-icon {
    font-size: 26px;
    margin-left: 15px;
    transition: all 0.4s ease;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.08));
}

.qarmani-ai-node:hover .qarmani-ai-icon {
    transform: scale(1.25) rotate(5deg);
    filter: drop-shadow(0 0 8px rgba(168, 85, 247, 0.5));
}

.qarmani-ai-name {
    font-size: 15px;
    font-weight: 800;
    transition: color 0.3s ease;
    line-height: 1.4;
}

.qarmani-ai-node:hover .qarmani-ai-name {
    color: #6366f1;
}

/* ========================================= */
/* بوابة الذكاء الاصطناعي الفخمة (AI Gateway) */
/* ========================================= */

@keyframes aqxAiTechGradient {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
}

.aqx-ai-luxury-gateway {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    /* لون تكنولوجي شيك: بنفسجي ونيون متوسط السطوع */
    background: linear-gradient(-45deg, rgba(99, 102, 241, 0.9), rgba(168, 85, 247, 0.88), rgba(139, 92, 246, 0.9), rgba(217, 70, 239, 0.88));
    background-size: 400% 400%;
    animation: aqxAiTechGradient 15s ease infinite;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    z-index: 999999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    direction: rtl;
    font-family: 'Tajawal', sans-serif;
}

.aqx-ai-luxury-gateway.active {
    opacity: 1;
    visibility: visible;
}

/* صندوق البوابة - فخامة متناهية */
.aqx-ai-gateway-content {
    background: rgba(255, 255, 255, 0.98);
    width: 92%;
    max-width: 480px;
    padding: 45px 35px;
    border-radius: 30px;
    box-shadow: 0 35px 70px rgba(0, 0, 0, 0.25), 
                0 0 50px rgba(168, 85, 247, 0.5), 
                inset 0 0 20px rgba(255, 255, 255, 1);
    text-align: center;
    position: relative;
    transform: translateY(60px) scale(0.85);
    transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    border: 2px solid rgba(255, 255, 255, 0.9);
}

.aqx-ai-luxury-gateway.active .aqx-ai-gateway-content {
    transform: translateY(0) scale(1);
}

/* زر الإغلاق الدوار والمتغير الألوان */
@keyframes aqxAiCloseSpin {
    0% { color: #f43f5e; transform: rotate(0deg); }
    50% { color: #fb7185; transform: rotate(180deg); }
    100% { color: #f43f5e; transform: rotate(360deg); }
}

.aqx-ai-close-btn {
    position: absolute;
    top: -15px;
    right: -15px;
    width: 45px;
    height: 45px;
    background: #ffffff;
    border: 2px solid #f43f5e;
    border-radius: 50%;
    font-size: 20px;
    font-weight: bold;
    cursor: pointer;
    color: #f43f5e;
    box-shadow: 0 5px 15px rgba(244, 63, 94, 0.3);
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    outline: none;
    z-index: 10;
}

.aqx-ai-close-btn:hover {
    animation: aqxAiCloseSpin 0.5s ease;
    background: #f43f5e;
    color: #ffffff;
    box-shadow: 0 8px 25px rgba(244, 63, 94, 0.5);
}

.aqx-ai-gateway-title {
    font-size: 26px;
    font-weight: 800;
    color: #1e1b4b;
    margin-top: 5px;
    margin-bottom: 15px;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.05);
}

.aqx-ai-gateway-desc {
    font-size: 16px;
    font-weight: 700;
    color: #64748b;
    margin-bottom: 30px;
    line-height: 1.7;
    padding: 0 10px;
}

/* إطار الإعلان بنبضات النيون البنفسجية */
@keyframes aqxAiNeonPulse {
    0% { box-shadow: 0 0 10px rgba(192, 132, 252, 0.3); }
    50% { box-shadow: 0 0 25px rgba(168, 85, 247, 0.6); }
    100% { box-shadow: 0 0 10px rgba(192, 132, 252, 0.3); }
}

.aqx-ai-ad-container {
    width: 300px;
    height: 250px;
    margin: 0 auto 30px;
    background: #f8fafc;
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    animation: aqxAiNeonPulse 2.5s infinite;
    border: 2px solid transparent;
    background-clip: padding-box, border-box;
    background-origin: padding-box, border-box;
    background-image: linear-gradient(#f8fafc, #f8fafc), linear-gradient(135deg, #818cf8, #d946ef);
}

/* مؤقت زمني أنيق */
.aqx-ai-gateway-timer {
    font-size: 18px;
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 25px;
    background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
    padding: 12px 25px;
    border-radius: 50px;
    display: inline-block;
    box-shadow: inset 0 2px 5px rgba(0,0,0,0.05);
}

.aqx-ai-gateway-timer span {
    color: #8b5cf6;
    font-size: 24px;
    font-weight: 900;
    margin: 0 8px;
    text-shadow: 0 2px 10px rgba(139, 92, 246, 0.3);
}

/* زر الدخول - تأثير فخم ومستقبلي */
.aqx-ai-enter-btn {
    display: block;
    width: 100%;
    padding: 16px 0;
    background: linear-gradient(135deg, #6366f1, #a855f7, #d946ef);
    background-size: 200% auto;
    color: #ffffff;
    border: none;
    border-radius: 16px;
    font-size: 20px;
    font-weight: 800;
    font-family: 'Tajawal', sans-serif;
    cursor: pointer;
    transition: all 0.4s ease;
    box-shadow: 0 10px 25px rgba(168, 85, 247, 0.35);
    outline: none;
    position: relative;
    overflow: hidden;
}

.aqx-ai-enter-btn:hover {
    background-position: right center;
    transform: translateY(-4px);
    box-shadow: 0 15px 35px rgba(168, 85, 247, 0.5);
}

@media (max-width: 480px) {
    .aqx-ai-gateway-content {
        padding: 40px 20px 30px;
        width: 95%;
    }
    .aqx-ai-ad-container {
        transform: scale(0.95);
        margin-bottom: 20px;
    }
    .aqx-ai-close-btn {
        top: -10px;
        right: -10px;
    }
}
</style>

