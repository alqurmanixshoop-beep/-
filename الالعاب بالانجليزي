let soundEnabled = true;
let currentModal = null;
let countdownInterval = null;
const AudioContext = window.AudioContext || window.webkitAudioContext;
let audioCtx = null;

function getAudioCtx() {
  if (!audioCtx) audioCtx = new AudioContext();
  return audioCtx;
}

// ===== SOUND EFFECTS =====
function playTone(freq, type = 'sine', duration = 0.1, vol = 0.3) {
  if (!soundEnabled) return;
  try {
    const ctx = getAudioCtx();
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.connect(gain);
    gain.connect(ctx.destination);
    osc.type = type;
    osc.frequency.setValueAtTime(freq, ctx.currentTime);
    osc.frequency.exponentialRampToValueAtTime(freq * 0.5, ctx.currentTime + duration);
    gain.gain.setValueAtTime(vol, ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + duration);
    osc.start(ctx.currentTime);
    osc.stop(ctx.currentTime + duration);
  } catch(e) {}
}

function playHoverSound() { playTone(440, 'sine', 0.06, 0.1); }
function playClickSound() {
  if (!soundEnabled) return;
  try {
    const ctx = getAudioCtx();
    [523, 659, 784, 1047].forEach((f, i) => {
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain); gain.connect(ctx.destination);
      osc.frequency.value = f; osc.type = 'triangle';
      gain.gain.setValueAtTime(0.2, ctx.currentTime + i * 0.07);
      gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + i * 0.07 + 0.1);
      osc.start(ctx.currentTime + i * 0.07);
      osc.stop(ctx.currentTime + i * 0.07 + 0.15);
    });
  } catch(e) {}
}

function playLaunchSound() {
  if (!soundEnabled) return;
  try {
    const ctx = getAudioCtx();
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.connect(gain); gain.connect(ctx.destination);
    osc.type = 'sawtooth';
    osc.frequency.setValueAtTime(200, ctx.currentTime);
    osc.frequency.exponentialRampToValueAtTime(1200, ctx.currentTime + 0.8);
    gain.gain.setValueAtTime(0.4, ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.8);
    osc.start(ctx.currentTime);
    osc.stop(ctx.currentTime + 0.8);
  } catch(e) {}
}

function toggleSound() {
  soundEnabled = !soundEnabled;
  document.getElementById('aqx-sound-toggle').textContent = soundEnabled ? '🔊' : '🔇';
  if (soundEnabled) playTone(880, 'sine', 0.15, 0.3);
}

// ===== RENDER CARDS =====
function renderCards(list) {
  const grid = document.getElementById('aqx-grid');
  grid.innerHTML = '';
  if (!list.length) {
    grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;color:rgba(255,255,255,0.3);padding:60px;font-size:18px;">😅 No games found for your search</div>';
    return;
  }
  list.forEach((g, idx) => {
    const card = document.createElement('div');
    card.className = 'aqx-card';
    card.dataset.cat = g.cat;
    card.dataset.id = g.id;
    card.style.setProperty('--card-color', g.color);
    card.style.setProperty('--card-color2', g.color2);
    card.style.animationDelay = (idx * 0.05) + 's';

    card.innerHTML = `
      <div class="aqx-card-img-wrap">
        <div class="aqx-card-thumb" style="background:linear-gradient(135deg,${g.color}33,${g.color2}55)">
          ${g.icon}
        </div>
        ${g.badge ? `<div class="aqx-badge">${g.badge}</div>` : ''}
      </div>
      <div class="aqx-card-body">
        <div class="aqx-card-title">${g.name}</div>
        <div class="aqx-card-desc">${g.desc}</div>
        <div class="aqx-card-footer">
          <div class="aqx-stars">${'★'.repeat(g.stars)}${'☆'.repeat(5-g.stars)}</div>
          <button class="aqx-play-btn" style="background:linear-gradient(135deg,${g.color},${g.color2})">Play Now</button>
        </div>
      </div>
    `;

    card.addEventListener('mouseenter', () => playHoverSound());
    card.addEventListener('click', () => openGameModal(g, card));
    grid.appendChild(card);
  });
  document.getElementById('game-count').textContent = AQX_GAMES.length;
}

// ===== FILTER =====
let currentCat = 'all';

function filterGames() {
  const q = document.getElementById('aqx-search').value.trim().toLowerCase();
  const filtered = AQX_GAMES.filter(g => {
    const matchCat = currentCat === 'all' || g.cat === currentCat;
    const matchQ = !q || g.name.toLowerCase().includes(q) || g.desc.toLowerCase().includes(q);
    return matchCat && matchQ;
  });
  renderCards(filtered);
}

function filterCat(btn, cat) {
  document.querySelectorAll('.aqx-cat').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  currentCat = cat;
  playTone(330, 'triangle', 0.08, 0.2);
  filterGames();
}

// ===== MODAL =====
function openGameModal(game, cardEl) {
  playClickSound();

  // Flip the card
  cardEl.classList.add('flipping');
  setTimeout(() => cardEl.classList.remove('flipping'), 700);

  // Remove existing modal
  if (currentModal) {
    document.body.removeChild(currentModal);
    if (countdownInterval) clearInterval(countdownInterval);
  }

  // Create overlay
  const overlay = document.createElement('div');
  overlay.className = 'aqx-modal-overlay';

  // Create particles HTML
  let particlesHTML = '';
  const colors = [game.color, game.color2, '#FFD700', '#FF69B4', '#fff'];
  for (let i = 0; i < 20; i++) {
    const c = colors[i % colors.length];
    const x = Math.random() * 100;
    const dur = 1.5 + Math.random() * 3;
    const delay = Math.random() * 2;
    const size = 3 + Math.random() * 6;
    particlesHTML += `<div class="aqx-particle" style="left:${x}%;background:${c};width:${size}px;height:${size}px;animation-duration:${dur}s;animation-delay:${delay}s;"></div>`;
  }

  overlay.innerHTML = `
    <div class="aqx-modal">
      <div class="aqx-modal-inner">
        <div class="aqx-modal-particles">${particlesHTML}</div>
        <div class="aqx-modal-game-icon">${game.icon}</div>
        <div class="aqx-modal-welcome">🎮 Welcome to</div>
        <h2 class="aqx-modal-game-name">${game.name}</h2>
        <div class="aqx-modal-site">✨ Alqurmani X AQX ✨</div>
        <div class="aqx-modal-divider"></div>
        <div class="aqx-modal-desc">${game.desc}</div>
        <div class="aqx-modal-countdown">
          <div class="aqx-countdown-bar-wrap">
            <div class="aqx-countdown-bar"></div>
          </div>
          <div class="aqx-countdown-num" id="modal-timer">3</div>
        </div>
        <div class="aqx-modal-launching">🚀 Loading game...</div>
      </div>
    </div>
  `;

  document.body.appendChild(overlay);
  currentModal = overlay;

  // Countdown
  let secs = 3;
  const timerEl = overlay.querySelector('#modal-timer');
  playLaunchSound();

  countdownInterval = setInterval(() => {
    secs--;
    if (timerEl) timerEl.textContent = secs;
    playTone(300 + secs * 100, 'sine', 0.08, 0.25);
    if (secs <= 0) {
      clearInterval(countdownInterval);
      // Launch game
      setTimeout(() => {
        if (currentModal) {
          document.body.removeChild(currentModal);
          currentModal = null;
        }
        if (game.link && game.link !== '#') {
          window.location.href = game.link;
        } else {
          showPlaceholder(game);
        }
      }, 400);
    }
  }, 1000);

  // Close on overlay click
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) {
      clearInterval(countdownInterval);
      document.body.removeChild(overlay);
      currentModal = null;
    }
  });
}

function showPlaceholder(game) {
  const msg = document.createElement('div');
  msg.style.cssText = `
    position:fixed;inset:0;z-index:99999;display:flex;align-items:center;justify-content:center;
    background:rgba(0,0,0,0.9);backdrop-filter:blur(10px);
  `;
  msg.innerHTML = `
    <div style="text-align:center;color:#fff;direction:ltr;padding:40px;max-width:400px;">
      <div style="font-size:80px;margin-bottom:20px;">${game.icon}</div>
      <h2 style="font-family:'Orbitron',sans-serif;color:#FFD700;margin:0 0 15px;">${game.name}</h2>
      <p style="color:rgba(255,255,255,0.6);font-family:'Tajawal',sans-serif;line-height:1.7;">
        Link not added yet. Replace <strong style="color:#FFD700;">#</strong> in the code with the real game URL.
      </p>
      <button onclick="this.parentElement.parentElement.remove()" style="
        margin-top:20px;padding:12px 30px;border-radius:25px;border:none;
        background:linear-gradient(135deg,${game.color},${game.color2});
        color:#fff;font-family:'Tajawal',sans-serif;font-size:15px;font-weight:700;
        cursor:pointer;
      ">Got it!</button>
    </div>
  `;
  msg.addEventListener('click', (e) => { if(e.target===msg) msg.remove(); });
  document.body.appendChild(msg);
}

