/* Games Grid */
.aqx-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 24px;
  padding: 0 30px 60px;
  max-width: 1400px;
  margin: 0 auto;
  position: relative;
  z-index: 10;
}

