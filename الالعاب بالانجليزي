/* Category Filter */
.aqx-cats {
  display: flex;
  justify-content: center;
  gap: 10px;
  margin-bottom: 40px;
  padding: 0 20px;
  flex-wrap: wrap;
  position: relative;
  z-index: 10;
}

.aqx-cat {
  padding: 8px 20px;
  border-radius: 30px;
  border: 1.5px solid rgba(255,255,255,0.2);
  background: rgba(255,255,255,0.05);
  color: rgba(255,255,255,0.7);
  font-family: 'Tajawal', sans-serif;
  font-size: 13px;
  cursor: pointer;
  transition: all 0.3s ease;
  backdrop-filter: blur(5px);
  margin: 0;
