}

@keyframes overlayIn {
  to { opacity: 1; }
}

.aqx-modal {
  position: relative;
  width: 90%;
  max-width: 480px;
  text-align: center;
  direction: ltr;
  animation: modalBounce 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
}

@keyframes modalBounce {
  0% { transform: scale(0.5) rotate(-5deg); opacity: 0; }
  70% { transform: scale(1.05) rotate(1deg); opacity: 1; }
  100% { transform: scale(1) rotate(0deg); opacity: 1; }
}

.aqx-modal-inner {
  background: linear-gradient(145deg, #1a0533, #0a1628, #001f3f);
  border-radius: 28px;
  padding: 40px 30px;
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.15);
}

.aqx-modal-inner::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
