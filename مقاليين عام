<div id="aqx-premium-posts" style="display: flex; gap: 20px; margin: 40px 0; flex-wrap: wrap;">
    <!-- المقال الأول -->
    <a id="card-1" href="#" style="flex: 1; min-width: 280px; text-decoration: none; padding: 25px; background: linear-gradient(135deg, #1a2a6c, #b21f1f, #fdbb2d); border-radius: 15px; color: #fff; box-shadow: 0 15px 30px rgba(0,0,0,0.2); transition: transform 0.4s ease, box-shadow 0.4s ease; display: block;">
        <span style="font-size: 11px; text-transform: uppercase; letter-spacing: 2px; opacity: 0.8;">مقترح لك</span>
        <h4 id="title-1" style="margin: 15px 0 0 0; font-size: 18px; line-height: 1.4; font-weight: 700;">جاري تحميل الفخامة...</h4>
    </a>

    <!-- المقال الثاني -->
    <a id="card-2" href="#" style="flex: 1; min-width: 280px; text-decoration: none; padding: 25px; background: linear-gradient(135deg, #000428, #004e92); border-radius: 15px; color: #fff; box-shadow: 0 15px 30px rgba(0,0,0,0.2); transition: transform 0.4s ease, box-shadow 0.4s ease; display: block;">
        <span style="font-size: 11px; text-transform: uppercase; letter-spacing: 2px; opacity: 0.8;">قراءة إضافية</span>
        <h4 id="title-2" style="margin: 15px 0 0 0; font-size: 18px; line-height: 1.4; font-weight: 700;">انتظر الإبداع...</h4>
    </a>
</div>

<style>
    #card-1:hover, #card-2:hover { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.3); }
</style>

<script>
(function() {
    var blogUrl = "https://www.alqurmanix.com"; 
    fetch(blogUrl + '/feeds/posts/default?alt=json&max-results=150')
    .then(response => response.json())
    .then(data => {
        var posts = data.feed.entry.filter(p => p.link.find(l => l.rel === 'alternate').href !== window.location.href);
        if (posts.length >= 2) {
            // اختيار عشوائي لمقالين
            var shuffled = posts.sort(() => 0.5 - Math.random());
            var p1 = shuffled[0];
            var p2 = shuffled[1];
            
            // تحديث المقال الأول
            document.getElementById('title-1').innerText = p1.title.$t;
            document.getElementById('card-1').href = p1.link.find(l => l.rel === 'alternate').href;
            
            // تحديث المقال الثاني
            document.getElementById('title-2').innerText = p2.title.$t;
            document.getElementById('card-2').href = p2.link.find(l => l.rel === 'alternate').href;
        }
    });
})();
</script>
