<div class="aqx-culinary-card" id="aqx-main-card-container">
  <div class="aqx-card-overlay"></div>
  <div class="aqx-card-content">
    <div class="aqx-card-badge">
      <span class="aqx-icon">👩‍🍳</span> توصية الشيف
    </div>

    <h3 class="aqx-main-title">
      استكشف روائع <span class="aqx-highlight">مطبخ القرمانى اكس</span>
    </h3>

    <div id="aqx-random-post-container">
      <div class="aqx-loading-box">
        <div class="aqx-shimmer"></div>
        جاري تحضير الوصفة المختارة... 🥘
      </div>
    </div>

    <button type="button" class="aqx-refresh-btn" id="aqx-refresh-btn">
      <span class="aqx-btn-text">اكتشف طبقاً آخر</span>
      <span class="aqx-refresh-icon">🔄</span>
    </button>
  </div>
</div>

<style>
@import url('https://fonts.googleapis.com/css2?family=Cairo:wght@600;900&family=Amiri:wght@700&display=swap');

/* الحاوية الرئيسية - احترافية ومشرقة بدون لون أسود */
.aqx-culinary-card {
  position: relative;
  overflow: hidden;
  direction: rtl;
  /* خلفية كريمية ناصعة وأنيقة */
  background: linear-gradient(135deg, #ffffff 0%, #fdfbf7 50%, #f5efe6 100%);
  border: 2px solid #d4af37;
  border-radius: 25px;
  padding: 30px;
  box-shadow: 0 15px 40px rgba(212, 175, 55, 0.15), 0 5px 15px rgba(0, 0, 0, 0.05);
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  font-family: 'Cairo', sans-serif;
  max-width: 450px;
  margin: 20px auto;
}

/* طبقة زخرفية خفيفة */
.aqx-card-overlay {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  opacity: 0.04;
  background-image: url('data:image/svg+xml;base64,');
  z-index: 1;
}

.aqx-card-content {
  position: relative;
  z-index: 2;
}

.aqx-culinary-card:hover {
  transform: translateY(-5px) scale(1.01);
  box-shadow: 0 20px 50px rgba(212, 175, 55, 0.25), 0 8px 20px rgba(0, 0, 0, 0.08);
}

/* البادج - توصية الشيف */
.aqx-card-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  border-radius: 50px;
  background: rgba(212, 175, 55, 0.15);
  border: 1px solid rgba(212, 175, 55, 0.4);
  color: #b59410;
  font-size: 13px;
  font-weight: 800;
  margin-bottom: 20px;
}

/* العنوان الرئيسي */
.aqx-main-title {
  margin: 0 0 25px;
  color: #3e2723; /* لون بني داكن احترافي بدل الأسود */
  font-size: 22px;
  line-height: 1.4;
  font-weight: 900;
}

.aqx-highlight {
  color: #d4af37;
  font-family: 'Amiri', serif;
  font-size: 1.2em;
}

/* اللودنج - تأثير الشيمر */
.aqx-loading-box {
  position: relative;
  text-align: center;
  padding: 40px 10px;
  color: #8d6e63;
  font-size: 16px;
  font-weight: 700;
  background: rgba(212, 175, 55, 0.05);
  border-radius: 15px;
  overflow: hidden;
}

.aqx-shimmer {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.1), transparent);
  animation: aqxShimmerInfinte 1.5s infinite;
}

@keyframes aqxShimmerInfinte {
  0% { transform: translateX(100%); }
  100% { transform: translateX(-100%); }
}

.aqx-post-link {
  text-decoration: none;
  display: block;
  animation: aqxSlideUp .5s ease-out;
}

/* بوكس المقال بلون فاتح */
.aqx-post-box {
  display: flex;
  align-items: center;
  gap: 18px;
  background: #ffffff;
  border: 1px solid rgba(212, 175, 55, 0.25);
  border-radius: 20px;
  padding: 15px;
  box-shadow: 0 4px 15px rgba(0,0,0,0.03);
  transition: all 0.3s ease;
}

.aqx-post-link:hover .aqx-post-box {
  background: #fdfbf7;
  border-color: #d4af37;
  transform: scale(1.03);
  box-shadow: 0 8px 25px rgba(212, 175, 55, 0.15);
}

/* الصورة */
.aqx-thumb {
  width: 95px;
  height: 95px;
  border-radius: 15px;
  overflow: hidden;
  flex-shrink: 0;
  background: #f5efe6;
  border: 2px solid rgba(212, 175, 55, 0.3);
  transition: border-color 0.3s ease;
}

.aqx-post-link:hover .aqx-thumb { border-color: #d4af37; }

.aqx-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.5s ease;
}
.aqx-post-link:hover .aqx-thumb img { transform: scale(1.1); }

.aqx-content { flex: 1; min-width: 0; }

.aqx-post-title {
  margin: 0;
  color: #4e342e; /* لون دافئ للقراءة */
  font-size: 16px;
  line-height: 1.6;
  font-weight: 800;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  transition: color 0.3s ease;
}

.aqx-post-link:hover .aqx-post-title { color: #b59410; }

/* السهم الذهبي */
.aqx-arrow {
  width: 35px; height: 35px;
  border-radius: 50%;
  background: rgba(212, 175, 55, 0.15);
  color: #b59410;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; font-size: 18px; font-weight: bold;
  transition: all 0.3s ease;
}

.aqx-post-link:hover .aqx-arrow {
  background: #d4af37;
  color: #fff;
  transform: translateX(-5px);
}

/* الزر الراقي */
.aqx-refresh-btn {
  width: 100%;
  margin-top: 20px;
  border: none;
  border-radius: 15px;
  padding: 14px 20px;
  cursor: pointer;
  background: linear-gradient(135deg, #d4af37 0%, #b59410 100%);
  color: #ffffff;
  font-size: 17px;
  font-weight: 800;
  font-family: 'Cairo', sans-serif;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  transition: all 0.3s ease;
  box-shadow: 0 6px 20px rgba(212, 175, 55, 0.3);
  position: relative;
  overflow: hidden;
}

.aqx-refresh-btn::after {
  content: '';
  position: absolute;
  top: -50%; left: -50%; width: 200%; height: 200%;
  background: rgba(255,255,255,0.2);
  transform: rotate(45deg);
  transition: 0.5s;
  opacity: 0;
}

.aqx-refresh-btn:hover {
  background: linear-gradient(135deg, #e5c354 0%, #d4af37 100%);
  box-shadow: 0 8px 25px rgba(212, 175, 55, 0.5);
  transform: translateY(-2px);
}

.aqx-refresh-btn:hover::after { opacity: 1; left: 100%; top: 100%; }
.aqx-refresh-btn:active { transform: translateY(1px); }

.aqx-refresh-icon { font-size: 20px; transition: .4s ease; }
.aqx-refresh-btn:hover .aqx-refresh-icon { transform: rotate(360deg) scale(1.1); }

@keyframes aqxSlideUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

@media(max-width:480px){
  .aqx-culinary-card { padding: 20px; }
  .aqx-post-box { padding: 12px; gap: 12px; }
  .aqx-thumb { width: 85px; height: 85px; }
  .aqx-post-title { font-size: 14px; }
  .aqx-main-title { font-size: 19px; }
}
</style>

<script>
/* الإعدادات */
var AQX_LABEL_NAME = "مطبخ القرمانى اكس";
var aqxAllPosts = [];
var aqxUsedIndexes = [];
var aqxCurrentPostUrl = window.location.href;

/* التفاعل الصوتي الفرفوش لبنت */
const aqxCheerfulPhrases = [
    "يا سلام على الحلاوة جربي الوصفة دي كده",
    "واو إيه رأيك في الطبق ده شكله يجنن",
    "أكلة تفتح النفس بجد يلا بينا",
    "طبق لذيذ جدا هتحبيه أوي",
    "جبتلك وصفة خطيرة شوفي التفاصيل"
];

/* دالة النطق الذكية والمفلترة بالكامل لمنع الرموز والهاشتاجات والأرقام */
function playCheerfulVoice(text) {
    try {
        if ('speechSynthesis' in window) {
            window.speechSynthesis.cancel();
            
            // فلتر صارم: مسح الهاشتاج والرموز وعلامات الترقيم والأرقام الإنجليزية والعربية تماماً
            let cleanText = text.replace(/[#_\.\!\?\:\-,\\\/\*\&\^%\$#\@\~`\"'\(\)\{\}\[\]\d٠-٩]/g, ' ');
            // إزالة المسافات العشوائية الناتجة عن المسح
            cleanText = cleanText.trim().replace(/\s+/g, ' ');

            if (!cleanText) return; // إذا كان النص فارغاً لا تنطق شيئاً

            const utterance = new SpeechSynthesisUtterance(cleanText);
            utterance.lang = 'ar-EG'; // اللهجة المصرية
            utterance.pitch = 1.6;    // نبرة صوت مرتفعة وأنثوية
            utterance.rate = 1.1;     // إيقاع سريع ومبهج
            window.speechSynthesis.speak(utterance);
        }
    } catch(e) { console.log(e); }
}

/* جلب المقالات من بلوجر */
function aqxFetchPosts(){
  var blogUrl = window.location.origin;
  var feedUrl = blogUrl + "/feeds/posts/default/-/" + encodeURIComponent(AQX_LABEL_NAME) + "?alt=json-in-script&callback=aqxLoadPosts&max-results=150";

  var oldScript = document.getElementById("aqx-feed-script");
  if(oldScript){ oldScript.remove(); }

  var script = document.createElement("script");
  script.src = feedUrl;
  script.id = "aqx-feed-script";
  document.body.appendChild(script);
}

/* استقبال وفلترة البيانات باحترافية */
function aqxLoadPosts(data){
  var container = document.getElementById("aqx-random-post-container");

  if(data.feed && data.feed.entry && data.feed.entry.length){
    var currentPath = new URL(aqxCurrentPostUrl, window.location.origin).pathname;

    aqxAllPosts = data.feed.entry.filter(function(entry){
      var postUrl = "";
      for(var i=0; i<entry.link.length; i++){
        if(entry.link[i].rel === "alternate"){
          postUrl = entry.link[i].href;
          break;
        }
      }
      if(!postUrl) return false;
      var postPath = new URL(postUrl, window.location.origin).pathname;
      return postPath !== currentPath; // استبعاد المقال الحالي بدقة
    });

    if(!aqxAllPosts.length){
      container.innerHTML = `<div class="aqx-loading-box">أنت تقرأ الوصفة الوحيدة المتاحة في هذا القسم حالياً</div>`;
      return;
    }

    aqxShufflePost(true); // جلب أول مقال صامت بدون صوت عند التحميل الأول لمنع التداخل
  }
  else{
    container.innerHTML = `<div class="aqx-loading-box">لم يتم العثور على وصفات في قسم (${AQX_LABEL_NAME})</div>`;
  }
}

/* عرض وصفة عشوائية */
function aqxShufflePost(isInitialLoad = false){
  var container = document.getElementById("aqx-random-post-container");

  var currentLink = container.querySelector('.aqx-post-link');
  if(currentLink) {
      currentLink.style.animation = 'aqxSlideUp 0.3s ease-in reverse forward';
      setTimeout(() => renderNewPost(isInitialLoad), 300);
  } else {
      renderNewPost(isInitialLoad);
  }

  function renderNewPost(silent) {
      if(aqxUsedIndexes.length >= aqxAllPosts.length){
        aqxUsedIndexes = [];
      }

      var randomIndex;
      do {
        randomIndex = Math.floor(Math.random() * aqxAllPosts.length);
      } while(aqxUsedIndexes.includes(randomIndex) && aqxAllPosts.length > 1);

      aqxUsedIndexes.push(randomIndex);

      var post = aqxAllPosts[randomIndex];
      var postTitle = post.title.$t;
      var postUrl = "#";

      for(var i=0; i<post.link.length; i++){
        if(post.link[i].rel === "alternate"){
          postUrl = post.link[i].href;
          break;
        }
      }

      var postImage = "https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEj-placeholder/s640/no-image.png";
      if(post.media$thumbnail){
        postImage = post.media$thumbnail.url.replace("/s72-c/","/s640/");
      }

      container.innerHTML = `
      <a class="aqx-post-link" href="${postUrl}">
        <div class="aqx-post-box">
          <div class="aqx-thumb">
            <img src="${postImage}" alt="${postTitle}" loading="lazy">
          </div>
          <div class="aqx-content">
            <h4 class="aqx-post-title">${postTitle}</h4>
          </div>
          <div class="aqx-arrow">←</div>
        </div>
      </a>
      `;

      // التفاعل الصوتي الفرفوش النظيف تماماً عند التغيير اليدوي
      if(!silent) {
          const randomPhrase = aqxCheerfulPhrases[Math.floor(Math.random() * aqxCheerfulPhrases.length)];
          playCheerfulVoice(randomPhrase);
      }
  }
}

/* الأحداث والمشغلات */
document.getElementById("aqx-refresh-btn").addEventListener("click", function(){
    playCheerfulVoice("ثواني هجيبلك حاجة تانية تعجبك");
    aqxShufflePost(false);
});

// التفاعل الصوتي عند المرور لأول مرة فوق الكارت
document.getElementById("aqx-main-card-container").addEventListener("mouseenter", function() {
    if(!this.hasAttribute('data-hovered')) {
        playCheerfulVoice("يا هلا بيكي في مطبخ القرماني إكس");
        this.setAttribute('data-hovered', 'true');
    }
}, {once: true});

document.addEventListener("DOMContentLoaded", aqxFetchPosts);
</script>
