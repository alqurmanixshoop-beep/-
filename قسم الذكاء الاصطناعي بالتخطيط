<style>
/* استدعاء خط تجوال الراقي */
@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght=500;700;800&display=swap');

.qarmani-ai-widget {
    font-family: 'Tajawal', sans-serif;
    direction: rtl;
    background: #ffffff;
    padding: 30px 20px;
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
    max-width: 100%;
    margin: 20px auto;
    border: 1px solid #f1f0f7;
}

.qarmani-ai-title {
    text-align: center;
    font-size: 26px;
    font-weight: 800;
    color: #4f46e5; /* لون بنفسجي ذكي */
    margin-bottom: 30px;
    position: relative;
    display: block;
}

/* خط تجميلي مستقبلي تحت العنوان */
.qarmani-ai-title::after {
    content: '';
    width: 70px;
    height: 4px;
    background: linear-gradient(90deg, #818cf8, #c084fc);
    display: block;
    margin: 10px auto 0;
    border-radius: 10px;
}

/* شبكة متناسقة تناسب الأعداد الكبيرة من البنود */
.qarmani-ai-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 12px;
}

.qarmani-ai-node {
    display: flex;
    align-items: center;
    padding: 14px 16px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    text-decoration: none;
    color: #1e293b;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    cursor: pointer;
}

/* تأثير التوهج النيون والمستقبلي الشيك جداً عند الحركية */
.qarmani-ai-node:hover {
    background: #ffffff;
    border-color: #a855f7;
    transform: translateY(-4px);
    box-shadow: 0 10px 20px rgba(168, 85, 247, 0.12);
}

.qarmani-ai-icon {
    font-size: 22px;
    margin-left: 12px;
    transition: all 0.3s ease;
}

.qarmani-ai-node:hover .qarmani-ai-icon {
    transform: scale(1.2);
    filter: drop-shadow(0 0 4px rgba(168, 85, 247, 0.4));
}

.qarmani-ai-name {
    font-size: 14px;
    font-weight: 700;
    transition: color 0.3s ease;
}

.qarmani-ai-node:hover .qarmani-ai-name {
    color: #6366f1;
}
</style>

