<div id="aqx-rahma-widget" class="aqx-va-container">
  
  <div class="aqx-va-bubble" id="aqx-rahma-bubble">
    <span class="aqx-bubble-title">✨ القرماني إكس</span>
    <p class="aqx-bubble-text">يا هلا وغلا! أنا رحمة.. تعالى دردش معايا 😉</p>
  </div>

  <div class="aqx-va-avatar-wrapper" onclick="aqxGoToWhatsApp()">
    <div class="aqx-online-indicator"></div>
    <div class="aqx-avatar-glow"></div>
    <img src="https://cdn-icons-png.flaticon.com/512/4140/4140047.png" alt="رحمة" class="aqx-va-img">
  </div>

</div>

<style>
/* التنسيقات الفخمة بدون أي ألوان داكنة */
.aqx-va-container {
  position: fixed;
  bottom: 30px;
  right: 30px;
  z-index: 99999;
  display: flex;
  align-items: flex-end;
  flex-direction: column;
  font-family: 'Tajawal', 'Cairo', sans-serif;
  direction: rtl;
}

/* فقاعة المحادثة (Glassmorphism) */
.aqx-va-bubble {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(15px);
  -webkit-backdrop-filter: blur(15px);
  border: 1px solid rgba(244, 114, 182, 0.3);
  box-shadow: 0 15px 35px rgba(236, 72, 153, 0.15);
  padding: 15px 20px;
  border-radius: 25px 25px 0 25px;
  margin-bottom: 15px;
  margin-right: 10px;
  max-width: 220px;
  opacity: 0;
  transform: translateY(20px) scale(0.8);
  transition: all 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  pointer-events: none;
  transform-origin: bottom right;
}
.aqx-show-bubble {
  opacity: 1;
  transform: translateY(0) scale(1);
}
.aqx-bubble-title {
  display: block;
  font-size: 11px;
  color: #ec4899;
  font-weight: 900;
  margin-bottom: 4px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.aqx-bubble-text {
  margin: 0;
  font-size: 14px;
  color: #0f172a;
  font-weight: 700;
  line-height: 1.5;
}

/* الأيقونة والتأثيرات */
.aqx-va-avatar-wrapper {
  position: relative;
  width: 70px;
  height: 70px;
  cursor: pointer;
  border-radius: 50%;
  transition: transform 0.3s ease;
}
.aqx-va-avatar-wrapper:hover {
  transform: scale(1.1) translateY(-5px);
}
.aqx-va-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
  border: 3px solid #fbcfe8;
  background: #fdf2f8;
  position: relative;
  z-index: 3;
  box-shadow: 0 10px 25px rgba(236, 72, 153, 0.2);
}
.aqx-online-indicator {
  position: absolute;
  top: 5px;
  right: 2px;
  width: 15px;
  height: 15px;
  background: #10b981;
  border: 3px solid #fff;
  border-radius: 50%;
  z-index: 4;
  box-shadow: 0 0 10px rgba(16, 185, 129, 0.5);
  animation: aqxOnlinePulse 2s infinite;
}
.aqx-avatar-glow {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  border-radius: 50%;
  background: radial-gradient(circle, #fbcfe8 0%, transparent 70%);
  z-index: 1;
  animation: aqxGlowPulse 3s infinite alternate;
  transform: scale(1.2);
}

/* حركات الاهتزاز والدلع */
.aqx-wiggle-active {
  animation: aqxDalaaWiggle 1s ease-in-out;
}
.aqx-jump-active {
  animation: aqxJoyJump 0.8s ease-in-out forwards;
}

@keyframes aqxOnlinePulse {
  0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
  70% { box-shadow: 0 0 0 8px rgba(16, 185, 129, 0); }
  100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
}
@keyframes aqxGlowPulse {
  0% { opacity: 0.4; transform: scale(1.1); }
  100% { opacity: 0.8; transform: scale(1.4); }
}
@keyframes aqxDalaaWiggle {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-10deg) translateY(-5px); }
  50% { transform: rotate(10deg) translateY(-5px); }
  75% { transform: rotate(-10deg) translateY(-5px); }
}
@keyframes aqxJoyJump {
  0% { transform: scale(1) translateY(0); }
  50% { transform: scale(1.2) translateY(-20px); }
  100% { transform: scale(0) translateY(-40px); opacity: 0; }
}

@media (max-width: 600px) {
  .aqx-va-container { bottom: 20px; right: 20px; }
  .aqx-va-avatar-wrapper { width: 60px; height: 60px; }
  .aqx-va-bubble { font-size: 13px; max-width: 190px; }
}
</style>

<script>
// متغير للتأكد إن الزائر تفاعل مع الصفحة عشان المتصفح يسمح بالصوت
let aqxUserInteracted = false;
document.body.addEventListener('click', function() {
  aqxUserInteracted = true;
}, {once: true});
document.body.addEventListener('touchstart', function() {
  aqxUserInteracted = true;
}, {once: true});

// دالة نطق الصوت (دلع وفرفشة)
function aqxSpeak(text, isPlayful = false) {
  if (!aqxUserInteracted) return; // منع الخطأ لو الزائر لسه ملمسش الشاشة
  
  // إلغاء أي صوت شغال حالياً
  window.speechSynthesis.cancel();
  
  let utterance = new SpeechSynthesisUtterance(text);
  utterance.lang = 'ar-EG'; // اللهجة المصرية
  utterance.rate = 1.05; // سرعة الكلام
  // ترفيع الصوت عشان يبقى بناتي وفيه دلع
  utterance.pitch = isPlayful ? 1.6 : 1.3; 
  
  window.speechSynthesis.speak(utterance);
}

// دالة إظهار رحمة كل دقيقة
function aqxTriggerRahma() {
  let widget = document.getElementById('aqx-rahma-widget');
  let bubble = document.getElementById('aqx-rahma-bubble');
  let avatar = document.querySelector('.aqx-va-avatar-wrapper');
  
  // حركة الاهتزاز (الدلع)
  avatar.classList.add('aqx-wiggle-active');
  // إظهار الرسالة
  bubble.classList.add('aqx-show-bubble');
  
  // التحدث بالترحيب
  aqxSpeak("يا هلا وغلا في القرماني إكس.. أنا رحمة.. تعالى دردش معايا", true);
  
  // إخفاء الرسالة بعد 6 ثواني
  setTimeout(() => {
    avatar.classList.remove('aqx-wiggle-active');
    bubble.classList.remove('aqx-show-bubble');
  }, 6000);
}

// تشغيل رحمة أوتوماتيك بعد 10 ثواني من دخول الموقع
setTimeout(aqxTriggerRahma, 10000);

// تكرار الحركة والتحدث كل دقيقة (60000 ملي ثانية)
setInterval(aqxTriggerRahma, 60000);

// دالة الضغط على الأيقونة للذهاب للواتساب
function aqxGoToWhatsApp() {
  // تفعيل التفاعل لو كان ده أول ضغطة
  aqxUserInteracted = true; 
  
  let widget = document.querySelector('.aqx-va-avatar-wrapper');
  let bubble = document.getElementById('aqx-rahma-bubble');
  
  // نطق الرسالة الحماسية
  aqxSpeak("يلا بينا مستنياك", true);
  
  // إخفاء الفقاعة وعمل حركة الانطلاق
  bubble.classList.remove('aqx-show-bubble');
  widget.classList.add('aqx-jump-active');
  
  // تحويل للواتساب بعد ثانية ونص (عشان تلحق تسمع الصوت)
  setTimeout(() => {
    // رقم الواتساب مع كود مصر (+20)
    window.open("https://wa.me/201027834695", "_blank");
    
    // إرجاع الأيقونة بعد التحويل
    setTimeout(() => {
      widget.classList.remove('aqx-jump-active');
    }, 1000);
  }, 1500);
}
</script>
