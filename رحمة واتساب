<div class="aqx-va-container" id="aqx-rahma-widget">
  
  <div class="aqx-va-bubble" id="aqx-rahma-bubble">
    <button class="aqx-va-close" onclick="aqxCloseRahma(event)">✖</button>
    <span class="aqx-bubble-title">✨ القرماني إكس</span>
    <p class="aqx-bubble-text">يا هلا وغلا! أنا رحمة.. تعالى دردش معايا 😉</p>
  </div>

  <div class="aqx-va-avatar-wrapper" onclick="aqxGoToWhatsApp()">
    <div class="aqx-online-indicator"></div>
    <div class="aqx-avatar-glow"></div>
    <img alt="رحمة" class="aqx-va-img" src="https://cdn-icons-png.flaticon.com/512/4140/4140047.png" />
  </div>

</div>

<style>
/* التنسيقات الفخمة الفاتحة */
.aqx-va-container {
  position: fixed;
  bottom: 30px;
  right: 30px;
  z-index: 999999;
  display: flex;
  align-items: flex-end;
  flex-direction: column;
  font-family: 'Tajawal', 'Cairo', sans-serif;
  direction: rtl;
}

/* فقاعة المحادثة (Glassmorphism) */
.aqx-va-bubble {
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(15px);
  -webkit-backdrop-filter: blur(15px);
  border: 1px solid rgba(244, 114, 182, 0.4);
  box-shadow: 0 15px 35px rgba(236, 72, 153, 0.15);
  padding: 18px 25px;
  border-radius: 25px 25px 0 25px;
  margin-bottom: 15px;
  margin-right: 15px;
  max-width: 240px;
  opacity: 0;
  transform: translateY(20px) scale(0.8);
  transition: all 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  pointer-events: none;
  transform-origin: bottom right;
  position: relative;
}
.aqx-show-bubble {
  opacity: 1;
  transform: translateY(0) scale(1);
  pointer-events: auto; /* للسماح بالضغط على زر الإغلاق */
}
.aqx-bubble-title {
  display: block;
  font-size: 11.5px;
  color: #ec4899;
  font-weight: 900;
  margin-bottom: 6px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.aqx-bubble-text {
  margin: 0;
  font-size: 14.5px;
  color: #0f172a;
  font-weight: 800;
  line-height: 1.6;
}

/* زر الإغلاق X */
.aqx-va-close {
  position: absolute;
  top: -8px;
  left: -8px;
  width: 24px;
  height: 24px;
  background: #f43f5e;
  color: white;
  border: none;
  border-radius: 50%;
  font-size: 11px;
  font-weight: bold;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 10px rgba(244, 63, 94, 0.3);
  transition: all 0.3s ease;
}
.aqx-va-close:hover {
  background: #e11d48;
  transform: scale(1.15) rotate(90deg);
}

/* الأيقونة والتأثيرات */
.aqx-va-avatar-wrapper {
  position: relative;
  width: 75px;
  height: 75px;
  cursor: pointer;
  border-radius: 50%;
  transition: transform 0.3s ease;
}
.aqx-va-avatar-wrapper:hover {
  transform: scale(1.08) translateY(-5px);
}
.aqx-va-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
  border: 3px solid #fbcfe8;
  background: #fdf2f8;
  position: relative;
  z-index: 3;
  box-shadow: 0 10px 25px rgba(236, 72, 153, 0.25);
}
.aqx-online-indicator {
  position: absolute;
  top: 6px;
  right: 4px;
  width: 16px;
  height: 16px;
  background: #10b981;
  border: 3px solid #fff;
  border-radius: 50%;
  z-index: 4;
  box-shadow: 0 0 12px rgba(16, 185, 129, 0.6);
  animation: aqxOnlinePulse 2s infinite;
}
.aqx-avatar-glow {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  border-radius: 50%;
  background: radial-gradient(circle, #fbcfe8 0%, transparent 70%);
  z-index: 1;
  animation: aqxGlowPulse 3s infinite alternate;
  transform: scale(1.2);
}

/* حركات الاهتزاز والدلع */
.aqx-wiggle-active {
  animation: aqxDalaaWiggle 1s ease-in-out;
}
.aqx-jump-active {
  animation: aqxJoyJump 0.8s ease-in-out forwards;
}

@keyframes aqxOnlinePulse {
  0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
  70% { box-shadow: 0 0 0 10px rgba(16, 185, 129, 0); }
  100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
}
@keyframes aqxGlowPulse {
  0% { opacity: 0.4; transform: scale(1.1); }
  100% { opacity: 0.8; transform: scale(1.4); }
}
@keyframes aqxDalaaWiggle {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-12deg) translateY(-6px); }
  50% { transform: rotate(12deg) translateY(-6px); }
  75% { transform: rotate(-12deg) translateY(-6px); }
}
@keyframes aqxJoyJump {
  0% { transform: scale(1) translateY(0); }
  50% { transform: scale(1.15) translateY(-25px); }
  100% { transform: scale(0) translateY(-50px); opacity: 0; }
}

@media (max-width: 600px) {
  .aqx-va-container { bottom: 20px; right: 20px; }
  .aqx-va-avatar-wrapper { width: 65px; height: 65px; }
  .aqx-va-bubble { font-size: 13px; max-width: 200px; padding: 15px 20px; }
}
</style>

<script>
let aqxUserInteracted = false;
let aqxHasSpokenWelcome = false;
const aqxClickSound = new Audio('https://actions.google.com/sounds/v1/ui/button_click.ogg');

// دالة نطق الصوت بدلع وفرفشة
function aqxSpeak(text, isPlayful = false) {
  if (!aqxUserInteracted) return; 
  window.speechSynthesis.cancel();
  let utterance = new SpeechSynthesisUtterance(text);
  utterance.lang = 'ar-EG'; 
  utterance.rate = 1.05; 
  utterance.pitch = isPlayful ? 1.6 : 1.3; 
  window.speechSynthesis.speak(utterance);
}

// تشغيل الصوت مع أول لمسة للصفحة (تخطي حظر المتصفح)
function aqxHandleFirstTouch() {
  aqxUserInteracted = true;
  if (!aqxHasSpokenWelcome && document.getElementById('aqx-rahma-bubble').classList.contains('aqx-show-bubble')) {
    aqxSpeak("يا هلا وغلا في القرماني إكس.. أنا رحمة.. تعالى دردش معايا", true);
    document.querySelector('.aqx-va-avatar-wrapper').classList.add('aqx-wiggle-active');
    aqxHasSpokenWelcome = true;
  }
  // إزالة الحدث بعد أول لمسة
  document.body.removeEventListener('click', aqxHandleFirstTouch);
  document.body.removeEventListener('touchstart', aqxHandleFirstTouch);
}

document.body.addEventListener('click', aqxHandleFirstTouch);
document.body.addEventListener('touchstart', aqxHandleFirstTouch);

// إظهار الرسالة تلقائياً عند فتح الصفحة
setTimeout(() => {
  let bubble = document.getElementById('aqx-rahma-bubble');
  bubble.classList.add('aqx-show-bubble');
}, 1500);

// دالة إغلاق النافذة (الزر X)
function aqxCloseRahma(event) {
  event.stopPropagation(); // منع انتقال الضغطة للأيقونة
  aqxClickSound.play().catch(e => {}); // تشغيل صوت كليك خفيف
  document.getElementById('aqx-rahma-bubble').classList.remove('aqx-show-bubble');
  window.speechSynthesis.cancel(); // إيقاف الصوت لو كان شغال
}

// دالة الضغط على رحمة والذهاب للواتساب
function aqxGoToWhatsApp() {
  aqxUserInteracted = true; 
  let widget = document.querySelector('.aqx-va-avatar-wrapper');
  let bubble = document.getElementById('aqx-rahma-bubble');
  
  aqxSpeak("يلا بينا مستنياك", true);
  
  bubble.classList.remove('aqx-show-bubble');
  widget.classList.add('aqx-jump-active');
  
  setTimeout(() => {
    // رسالة الواتساب الجاهزة والمشفرة
    let messageText = encodeURIComponent("مرحباً رحمة، أنا جاي من موقع القرماني إكس 💕 خلينا ندردش شوى  ...");
    window.open("https://wa.me/201027834695?text=" + messageText, "_blank");
    
    setTimeout(() => {
      widget.classList.remove('aqx-jump-active');
    }, 1000);
  }, 1500);
}
</script>
