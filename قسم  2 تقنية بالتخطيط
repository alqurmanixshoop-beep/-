    align-items: center;
    justify-content: center;
    outline: none;
    z-index: 10;
}

.aqx-close-btn:hover {
    animation: aqxCloseSpin 0.5s ease;
    background: #ff4757;
    color: #ffffff;
    box-shadow: 0 8px 25px rgba(255, 71, 87, 0.5);
}

.aqx-gateway-title {
    font-size: 26px;
    font-weight: 800;
    color: #0f172a;
    margin-top: 5px;
    margin-bottom: 15px;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.05);
}

.aqx-gateway-desc {
    font-size: 16px;
    font-weight: 500;
    color: #475569;
    margin-bottom: 30px;
    line-height: 1.7;
    padding: 0 10px;
}

/* إطار الإعلان - تصميم نبضي احترافي */
@keyframes aqxNeonPulse {
    0% { box-shadow: 0 0 10px rgba(13, 202, 240, 0.3); }
    50% { box-shadow: 0 0 25px rgba(13, 110, 253, 0.6); }
    100% { box-shadow: 0 0 10px rgba(13, 202, 240, 0.3); }
}

.aqx-ad-container {
    width: 300px;
    height: 250px;
    margin: 0 auto 30px;
    background: #f8fafc;
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    animation: aqxNeonPulse 2s infinite;
    border: 2px solid transparent;
    background-clip: padding-box, border-box;
    background-origin: padding-box, border-box;
    background-image: linear-gradient(#f8fafc, #f8fafc), linear-gradient(135deg, #0d6efd, #0dcaf0);
}

/* مؤقت زمني أنيق */
.aqx-gateway-timer {
    font-size: 18px;
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 25px;
    background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
    padding: 12px 25px;
    border-radius: 50px;
    display: inline-block;
    box-shadow: inset 0 2px 5px rgba(0,0,0,0.05);
}

.aqx-gateway-timer span {
    color: #0d6efd;
    font-size: 24px;
    font-weight: 900;
    margin: 0 8px;
    text-shadow: 0 2px 10px rgba(13, 110, 253, 0.3);
}

/* زر الدخول - تأثير فخم */
.aqx-enter-btn {
    display: block;
    width: 100%;
    padding: 16px 0;
    background: linear-gradient(135deg, #0d6efd, #0dcaf0);
    color: #ffffff;
    border: none;
    border-radius: 16px;
    font-size: 20px;
    font-weight: 800;
    font-family: 'Tajawal', sans-serif;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 10px 25px rgba(13, 110, 253, 0.3);
    outline: none;
    position: relative;
    overflow: hidden;
}

.aqx-enter-btn::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 50%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
    transition: all 0.5s ease;
}

.aqx-enter-btn:hover {
    transform: translateY(-4px);
    box-shadow: 0 15px 35px rgba(13, 110, 253, 0.45);
}

.aqx-enter-btn:hover::after {
    left: 100%;
}

@media (max-width: 480px) {
    .aqx-gateway-content {
        padding: 40px 20px 30px;
        width: 95%;
    }
    .aqx-ad-container {
        transform: scale(0.95);
        margin-bottom: 20px;
    }
    .aqx-close-btn {
        top: -10px;
        right: -10px;
    }
}
</style>

