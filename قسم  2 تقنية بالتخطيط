<!-- بداية كود أقسام التقنية والبوابة الفخمة المحدثة - القرماني إكس AQX -->
<style>
@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap');

/* تنسيقات الأداة الرئيسية (الأقسام) */
.qarmani-tech-widget {
    font-family: 'Tajawal', sans-serif;
    direction: rtl;
    background: #ffffff;
    padding: 40px 25px;
    border-radius: 24px;
    box-shadow: 0 15px 50px rgba(13, 110, 253, 0.08);
    max-width: 100%;
    margin: 0 auto;
    border: 1px solid #e2e8f0;
}

.qarmani-tech-title {
    text-align: center;
    font-size: 30px;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 45px;
    position: relative;
    display: block;
}

.qarmani-tech-title::after {
    content: '';
    width: 100px;
    height: 6px;
    background: linear-gradient(90deg, #0d6efd, #0dcaf0);
    display: block;
    margin: 15px auto 0;
    border-radius: 10px;
    box-shadow: 0 4px 15px rgba(13, 202, 240, 0.4);
}

.qarmani-tech-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 20px;
}

.qarmani-tech-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 25px 15px;
    background: #f8fafc;
    border: 2px solid #edf2f7;
    border-radius: 20px;
    text-decoration: none;
    color: #475569;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    position: relative;
    overflow: hidden;
    z-index: 1;
}

.qarmani-tech-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(13,110,253,0.05) 0%, rgba(13,202,240,0.1) 100%);
    z-index: -1;
    opacity: 0;
    transition: opacity 0.4s ease;
}

.qarmani-tech-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 30px rgba(13, 110, 253, 0.12);
    border-color: #0d6efd;
    background: #ffffff;
}

.qarmani-tech-card:hover::before {
    opacity: 1;
}

.qarmani-tech-icon {
    font-size: 42px;
    margin-bottom: 15px;
    transition: transform 0.4s ease;
    filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1));
}

.qarmani-tech-card:hover .qarmani-tech-icon {
    transform: scale(1.2) translateY(-5px);
}

.qarmani-tech-name {
    font-size: 16px;
    font-weight: 800;
    text-align: center;
    line-height: 1.5;
    transition: color 0.3s ease;
}

.qarmani-tech-card:hover .qarmani-tech-name {
    color: #0d6efd;
}

/* ========================================= */
/* البوابة الفخمة جداً (Luxury Gateway)      */
/* ========================================= */

/* تأثير الحركة للخلفية التقنية */
@keyframes aqxTechGradient {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
}

.aqx-luxury-gateway {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    /* لون تقني شيك متحرك: أزرق ملكي مع سماوي نيون - ليس غامقاً وليس فاتحاً */
    background: linear-gradient(-45deg, rgba(10, 88, 202, 0.9), rgba(0, 180, 216, 0.85), rgba(72, 149, 239, 0.9), rgba(67, 97, 238, 0.85));
    background-size: 400% 400%;
    animation: aqxTechGradient 15s ease infinite;
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    z-index: 999999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    direction: rtl;
    font-family: 'Tajawal', sans-serif;
}

.aqx-luxury-gateway.active {
    opacity: 1;
    visibility: visible;
}

/* صندوق البوابة - فخامة الزجاج المضيء */
.aqx-gateway-content {
    background: rgba(255, 255, 255, 0.97);
    width: 92%;
    max-width: 480px;
    padding: 45px 35px;
    border-radius: 30px;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.2), 
                0 0 40px rgba(0, 210, 255, 0.4), 
                inset 0 0 20px rgba(255, 255, 255, 1);
    text-align: center;
    position: relative;
    transform: translateY(60px) scale(0.85);
    transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    border: 2px solid rgba(255, 255, 255, 0.8);
}

.aqx-luxury-gateway.active .aqx-gateway-content {
    transform: translateY(0) scale(1);
}

/* زر الإغلاق الدوار والمتغير الألوان */
@keyframes aqxCloseSpin {
    0% { color: #ff4757; transform: rotate(0deg); }
    50% { color: #ff6b81; transform: rotate(180deg); }
    100% { color: #ff4757; transform: rotate(360deg); }
}

.aqx-close-btn {
