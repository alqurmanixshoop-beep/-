<!-- السكريبت التشغيلي الخالي من الأخطاء -->
<script>
let aqxTimerInterval;
let aqxTargetUrl = '#';

// دالة العبقرية لحقن الإعلان وضمان ظهوره 100%
function loadAqxAdSecurely() {
    const adContainer = document.getElementById('aqx-ad-container-inner');
    adContainer.innerHTML = ''; // تنظيف أي إعلان سابق
    
    // إنشاء إطار (Iframe) حي لحقن الإعلان بداخله بدون تعطيل الصفحة
    const iframe = document.createElement('iframe');
    iframe.width = "300";
    iframe.height = "250";
    iframe.frameBorder = "0";
    iframe.scrolling = "no";
    iframe.style.border = "none";
    iframe.style.overflow = "hidden";
    iframe.style.background = "transparent";
    adContainer.appendChild(iframe);

    // كتابة كود الإعلان داخل الإطار مباشرة
    const iframeDoc = iframe.contentWindow.document;
    iframeDoc.open();
    iframeDoc.write(`
        <!DOCTYPE html>
        <html>
        <head>
            <style>
                body { margin: 0; padding: 0; display: flex; justify-content: center; align-items: center; background: transparent; }
            </style>
        </head>
        <body>
            <script type="text/javascript">
                atOptions = {
                    'key' : '6e875cc37b483ebcf03c1a3b504e2982',
                    'format' : 'iframe',
                    'height' : 250,
                    'width' : 300,
                    'params' : {}
                };
            <\/script>
            <script type="text/javascript" src="https://www.highperformanceformat.com/6e875cc37b483ebcf03c1a3b504e2982/invoke.js"><\/script>
        </body>
        </html>
    `);
    iframeDoc.close();
}

function aqxOpenGateway(event, sectionName, sectionDesc) {
    event.preventDefault(); // إيقاف الانتقال الفوري
    aqxTargetUrl = event.currentTarget.getAttribute('href'); 

    // تحديث النصوص بحروف نقية بدون تنوين لمنع مشكلة الهاشتاج والأرقام
    document.getElementById('aqx-gateway-title').innerHTML = 'مرحبا بك في قسم ' + sectionName;
    document.getElementById('aqx-gateway-desc').innerHTML = sectionDesc;

    // إظهار البوابة الفخمة
    const gateway = document.getElementById('aqx-luxury-gateway');
    gateway.classList.add('active');

    // استدعاء دالة الإعلان فور ظهور البوابة
    loadAqxAdSecurely();

    // تشغيل المؤقت الزمني لـ 15 ثانية
    let timeLeft = 15;
    const timerSpan = document.getElementById('aqx-timer-count');
    timerSpan.innerText = timeLeft;

    clearInterval(aqxTimerInterval);
    aqxTimerInterval = setInterval(() => {
        timeLeft--;
        timerSpan.innerText = timeLeft;
        
        if (timeLeft <= 0) {
            clearInterval(aqxTimerInterval);
            window.location.href = aqxTargetUrl;
        }
    }, 1000);
}

function aqxCloseGateway() {
    clearInterval(aqxTimerInterval);
    document.getElementById('aqx-luxury-gateway').classList.remove('active');
    document.getElementById('aqx-ad-container-inner').innerHTML = ''; // إيقاف الإعلان عند الإغلاق لتخفيف الحمل
}

function aqxEnterNow() {
    clearInterval(aqxTimerInterval);
    window.location.href = aqxTargetUrl;
}
</script>
