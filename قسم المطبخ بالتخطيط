<style>
/* استدعاء خط تجوال الراقي */
@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@500;700;800&display=swap');

.qarmani-chef-widget {
    font-family: 'Tajawal', sans-serif;
    direction: rtl;
    /* خلفية كريمية دافئة جداً تناسب المأكولات */
    background: linear-gradient(135deg, #fffdfa 0%, #fcf7ef 100%);
    padding: 35px 25px;
    border-radius: 20px;
    box-shadow: 0 15px 40px rgba(138, 28, 28, 0.05);
    max-width: 100%;
    margin: 20px auto;
    border: 1px solid #f3e8d5;
}

.qarmani-chef-title {
    text-align: center;
    font-size: 28px;
    font-weight: 800;
    color: #4a1515; /* عنابي داكن فخم */
    margin-bottom: 35px;
    position: relative;
    display: block;
    letter-spacing: 0.5px;
}

/* زخرفة ذهبية فخمة تحت العنوان */
.qarmani-chef-title::after {
    content: '';
    width: 80px;
    height: 4px;
    background: linear-gradient(90deg, #d4af37, #f3e5ab, #d4af37);
    display: block;
    margin: 12px auto 0;
    border-radius: 10px;
    box-shadow: 0 2px 5px rgba(212, 175, 55, 0.4);
}

/* توزيع الأقسام بشكل شبكي مريح للعين */
.qarmani-chef-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 15px;
}

.qarmani-chef-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 20px 15px;
    background: #ffffff;
    border: 1px solid #f0e6d2;
    border-radius: 12px;
    text-decoration: none;
    color: #3b2f2f;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
    cursor: pointer;
}

/* تأثير الخط الذهبي السفلي الفاخر */
.qarmani-chef-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 0;
    background: linear-gradient(90deg, #d4af37, #c5a028);
    transition: height 0.3s ease;
    z-index: 1;
}

/* تأثير التفاعل والتحليق */
.qarmani-chef-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 30px rgba(74, 21, 21, 0.08);
    border-color: #d4af37;
}

.qarmani-chef-card:hover::after {
    height: 4px; /* يظهر الخط الذهبي */
}

.qarmani-chef-icon {
    font-size: 30px;
    margin-bottom: 12px;
    z-index: 2;
    transition: all 0.4s ease;
    filter: drop-shadow(0 4px 6px rgba(0,0,0,0.05));
}

.qarmani-chef-card:hover .qarmani-chef-icon {
    transform: scale(1.15) rotate(-5deg);
}

.qarmani-chef-name {
    font-size: 14.5px;
    font-weight: 700;
    text-align: center;
    line-height: 1.4;
    z-index: 2;
    transition: color 0.3s ease;
}

.qarmani-chef-card:hover .qarmani-chef-name {
    color: #8a1c1c; /* يتغير للون العنابي الراقي */
}
</style>

