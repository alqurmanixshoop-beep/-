<style>
/* استدعاء خط تجوال الراقي */
@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght=500;700;800&display=swap');

.qarmani-islam-widget {
    font-family: 'Tajawal', sans-serif;
    direction: rtl;
    background: #ffffff;
    padding: 30px 20px;
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03);
    max-width: 100%;
    margin: 20px auto;
    border: 1px solid #e6f4f1;
}

.qarmani-islam-title {
    text-align: center;
    font-size: 26px;
    font-weight: 800;
    color: #065f46; /* أخضر عميق وراقي جداً */
    margin-bottom: 30px;
    position: relative;
    display: block;
}

/* خط تجميلي متدرج تحت العنوان */
.qarmani-islam-title::after {
    content: '';
    width: 70px;
    height: 4px;
    background: linear-gradient(90deg, #059669, #34d399);
    display: block;
    margin: 10px auto 0;
    border-radius: 10px;
}

/* توزيع الأقسام بنظام الكبسولات المرنة */
.qarmani-islam-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
}

.qarmani-islam-badge {
    display: flex;
    align-items: center;
    padding: 12px 20px;
    background: #f0fdf4; /* خلفية هادئة مريحة */
    border: 1px solid #d1fae5;
    border-radius: 30px; /* شكل كبسولة دائري مميز */
    text-decoration: none;
    color: #1e293b;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
}

/* تأثير التفاعل الفخم عند مرور الماوس */
.qarmani-islam-badge:hover {
    background: #ffffff;
    border-color: #059669;
    transform: scale(1.04); /* تكبير انسيابي خفيف */
    box-shadow: 0 8px 20px rgba(5, 150, 105, 0.12);
}

.qarmani-islam-icon {
    font-size: 20px;
    margin-left: 12px;
    transition: transform 0.3s ease;
}

.qarmani-islam-badge:hover .qarmani-islam-icon {
    transform: rotate(15deg) scale(1.1);
}

.qarmani-islam-name {
    font-size: 14px;
    font-weight: 700;
    transition: color 0.3s ease;
}

.qarmani-islam-badge:hover .qarmani-islam-name {
    color: #059669;
}
</style>

