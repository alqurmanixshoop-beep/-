<style>

/* AQX PREMIUM ARTICLE ALERT */

#aqx-premium-alert{

position:fixed;

top:-200px;

left:50%;

transform:translateX(-50%);

width:94%;

max-width:950px;

z-index:999999;

background:

linear-gradient(135deg,#7a0000,#d10000,#ff2b2b);

border-radius:0 0 26px 26px;

padding:18px 25px;

display:flex;

align-items:center;

gap:18px;

overflow:hidden;

transition:all .9s cubic-bezier(.68,-0.6,.32,1.6);

box-shadow:

0 15px 40px rgba(255,0,0,.45),

0 0 25px rgba(255,60,60,.3);

border:1px solid rgba(255,255,255,.12);

backdrop-filter:blur(10px);

direction:rtl;

}



#aqx-premium-alert.show{

top:0;

}



#aqx-premium-alert::before{

content:'';

position:absolute;

top:0;

left:-120%;

width:50%;

height:100%;

background:rgba(255,255,255,.14);

transform:skewX(-25deg);

animation:aqxshine 5s linear infinite;

}



@keyframes aqxshine{

100%{

left:170%;

}

}



.aqx-icon{

width:58px;

height:58px;

min-width:58px;

border-radius:50%;

display:flex;

align-items:center;

justify-content:center;

font-size:28px;

background:rgba(255,255,255,.12);

box-shadow:0 0 18px rgba(255,255,255,.25);

animation:aqxpulse 2s infinite;

}



@keyframes aqxpulse{

0%{transform:scale(1);}

50%{transform:scale(1.08);}

100%{transform:scale(1);}

}



.aqx-content{

flex:1;

overflow:hidden;

}



.aqx-top{

font-size:15px;

font-weight:700;

color:#fff;

opacity:.9;

margin-bottom:7px;

font-family:Tajawal,sans-serif;

}



.aqx-link{

display:block;

color:#fff;

font-size:21px;

font-weight:800;

line-height:1.8;

text-decoration:none;

font-family:Tajawal,sans-serif;

word-break:break-word;

transition:.3s;

}



.aqx-link:hover{

opacity:.85;

transform:translateX(-4px);

}



.aqx-close{

width:42px;

height:42px;

min-width:42px;

border-radius:50%;

display:flex;

align-items:center;

justify-content:center;

font-size:22px;

cursor:pointer;

background:rgba(255,255,255,.12);

color:#fff;

transition:.3s;

font-family:Arial;

}



.aqx-close:hover{

background:#fff;

color:#c40000;

transform:rotate(90deg);

}



.aqx-progress{

position:absolute;

bottom:0;

right:0;

height:4px;

width:100%;

background:rgba(255,255,255,.12);

overflow:hidden;

}



.aqx-progress span{

display:block;

height:100%;

width:100%;

background:#fff;

transform-origin:right;

animation:aqxprogress 12s linear forwards;

}



@keyframes aqxprogress{

from{

transform:scaleX(1);

}

to{

transform:scaleX(0);

}

}



@media(max-width:768px){



#aqx-premium-alert{

padding:14px 16px;

gap:12px;

}



.aqx-link{

font-size:17px;

line-height:1.7;

}



.aqx-icon{

width:50px;

height:50px;

font-size:23px;

}



}

</style>



<div id="aqx-premium-alert">



<div class="aqx-icon">🔥</div>



<div class="aqx-content">

<div class="aqx-top">

مقال قرمانى قد يعجبك

</div>



<a class="aqx-link" href="#" target="_blank">

جاري تحميل المقال...

</a>

</div>



<div class="aqx-close" id="aqx-close-btn">

×

</div>



<div class="aqx-progress">

<span></span>

</div>



</div>



<script>

(async function(){



const feedUrl="/feeds/posts/default?alt=json&max-results=999";

const alertBox=document.getElementById("aqx-premium-alert");

const alertLink=document.querySelector(".aqx-link");

const closeBtn=document.getElementById("aqx-close-btn");

const progress=document.querySelector(".aqx-progress span");



let shownPosts=[];



async function getRandomPost(){



try{



const response=await fetch(feedUrl);

const data=await response.json();



const entries=data.feed.entry;



if(!entries || entries.length===0) return;



/* استبعاد المقال الحالي */

const currentUrl=window.location.href;



const filtered=entries.filter(post=>{



let postLink="";



for(let i=0;i<post.link.length;i++){

if(post.link[i].rel==="alternate"){

postLink=post.link[i].href;

break;

}

}



return postLink !== currentUrl;



});



/* منع تكرار المقالات */

const available=filtered.filter(post=>{



const title=post.title.$t;



return !shownPosts.includes(title);



});



if(available.length===0){

shownPosts=[];

return getRandomPost();

}



const randomPost=available[Math.floor(Math.random()*available.length)];



const title=randomPost.title.$t;



let link="#";



for(let i=0;i<randomPost.link.length;i++){

if(randomPost.link[i].rel==="alternate"){

link=randomPost.link[i].href;

break;

}

}



shownPosts.push(title);



alertLink.textContent=title;

alertLink.href=link;



alertBox.classList.add("show");



progress.style.animation="none";

progress.offsetHeight;

progress.style.animation="aqxprogress 12s linear forwards";



/* اختفاء بعد 12 ثانية */

setTimeout(()=>{

alertBox.classList.remove("show");

},12000);



}catch(error){

console.log(error);

}



}



/* زر الإغلاق */

closeBtn.onclick=function(){

alertBox.classList.remove("show");

};



/* أول ظهور بعد 5 ثواني */

setTimeout(()=>{

getRandomPost();



/* تكرار كل دقيقة */

setInterval(()=>{

getRandomPost();

},60000);



},5000);



})();

</script>
