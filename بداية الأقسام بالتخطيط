<!-- AQX MASTER PREMIUM WIDGET -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<style>
@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@500;700;800;900&display=swap');

:root{
    --aqx-bg-1:#0f172a;
    --aqx-bg-2:#1e1b4b;
    --aqx-text:#ffffff;
    --aqx-sub:#cbd5e1;
}

.aqx-master-widget{
    font-family:'Tajawal',sans-serif;
    direction:rtl;
    position:relative;
    overflow:hidden;

    background:
    linear-gradient(145deg,var(--aqx-bg-1),var(--aqx-bg-2));

    padding:42px 22px;
    border-radius:28px;

    text-align:center;

    border:1px solid rgba(255,255,255,.08);

    box-shadow:
    0 10px 30px rgba(0,0,0,.35),
    0 20px 60px rgba(0,0,0,.25);

    margin:25px auto 45px auto;

    transition:
    transform .35s ease,
    box-shadow .35s ease,
    border-color .35s ease;

    isolation:isolate;

    -webkit-tap-highlight-color:transparent;
}

/* خلفية التوهج */
.aqx-master-widget::before{
    content:'';
    position:absolute;
    inset:-50%;

    background:
    radial-gradient(circle,
    rgba(99,102,241,.18) 0%,
    transparent 60%);

    animation:aqxRotateGlow 18s linear infinite;

    z-index:0;
}

.aqx-master-widget::after{
    content:'';
    position:absolute;
    inset:0;

    background:
    linear-gradient(
    180deg,
    rgba(255,255,255,.06),
    rgba(255,255,255,0)
    );

    pointer-events:none;
    z-index:0;
}

@keyframes aqxRotateGlow{
    from{
        transform:rotate(0deg);
    }
    to{
        transform:rotate(360deg);
    }
}

@media (hover:hover){

.aqx-master-widget:hover{
    transform:translateY(-6px);

    border-color:rgba(0,255,255,.4);

    box-shadow:
    0 18px 40px rgba(0,0,0,.45),
    0 20px 70px rgba(0,255,255,.15),
    0 0 40px rgba(255,0,255,.12);
}

}

.aqx-content-wrapper{
    position:relative;
    z-index:2;
}

.aqx-main-title{
    margin:0 0 18px;

    font-size:clamp(28px,5vw,42px);

    font-weight:900;

    color:var(--aqx-text);

    line-height:1.3;

    text-shadow:
    0 4px 10px rgba(0,0,0,.5);
}

/* AQX نييون متحرك احترافى */
.aqx-highlight{
    display:inline-block;

    font-size:1.15em;

    font-weight:900;

    letter-spacing:3px;

    background:
    linear-gradient(
        90deg,
        #ff0080,
        #00e5ff,
        #7cff00,
        #ffd000,
        #ff0080
    );

    background-size:400% auto;

    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;

    animation:
    aqxNeonFlow 5s linear infinite,
    aqxPulseZoom 2s ease-in-out infinite;

    filter:
    drop-shadow(0 0 6px rgba(255,255,255,.6))
    drop-shadow(0 0 15px rgba(0,229,255,.7))
    drop-shadow(0 0 25px rgba(255,0,128,.6));
}

@keyframes aqxNeonFlow{
    0%{
        background-position:0% center;
    }

    100%{
        background-position:400% center;
    }
}

@keyframes aqxPulseZoom{

    0%{
        transform:scale(1);
    }

    25%{
        transform:scale(1.12) rotate(-2deg);
    }

    50%{
        transform:scale(1.2);
    }

    75%{
        transform:scale(1.1) rotate(2deg);
    }

    100%{
        transform:scale(1);
    }
}

.aqx-description{
    font-size:17px;

    font-weight:500;

    color:var(--aqx-sub);

    line-height:1.9;

    max-width:700px;

    margin:0 auto 28px;
}

.aqx-audio-hint{
    display:inline-flex;
    align-items:center;
    gap:8px;

    font-size:13px;

    color:#cbd5e1;

    background:rgba(255,255,255,.05);

    padding:8px 16px;

    border-radius:999px;

    border:1px solid rgba(255,255,255,.08);

    backdrop-filter:blur(8px);

    animation:aqxPulse 2.5s infinite;
}

@keyframes aqxPulse{
    0%{
        opacity:.7;
        transform:scale(1);
    }

    50%{
        opacity:1;
        transform:scale(1.04);
    }

    100%{
        opacity:.7;
        transform:scale(1);
    }
}

.aqx-pointer{
    margin-top:18px;

    font-size:48px;

    display:inline-block;

    animation:aqxBounce 1.7s infinite;

    filter:
    drop-shadow(0 5px 15px rgba(255,255,255,.2));
}

@keyframes aqxBounce{

    0%,20%,50%,80%,100%{
        transform:translateY(0);
    }

    40%{
        transform:translateY(14px);
    }

    60%{
        transform:translateY(7px);
    }
}

/* Ripple */
.aqx-ripple{
    position:absolute;

    border-radius:50%;

    background:rgba(255,255,255,.35);

    transform:scale(0);

    animation:aqxRipple .7s linear;

    pointer-events:none;

    z-index:1;
}

@keyframes aqxRipple{
    to{
        transform:scale(4);
        opacity:0;
    }
}

@media(max-width:768px){

.aqx-master-widget{
    padding:35px 18px;
    border-radius:22px;
}

.aqx-description{
    font-size:15px;
}

.aqx-pointer{
    font-size:42px;
}

.aqx-highlight{
    letter-spacing:2px;
}

}

@media (prefers-reduced-motion: reduce){

*{
    animation:none !important;
    transition:none !important;
}

}
</style>

<div class="aqx-master-widget" id="aqxWidget">

    <div class="aqx-content-wrapper">

        <h1 class="aqx-main-title">
            أقسام القرمانى اكس
            <span class="aqx-highlight">AQX</span>
        </h1>

        <p class="aqx-description">
            مرحباً بك في عالمنا الشامل والمتنوع!
            من أحدث التقنيات وعالم المال،
            إلى فنون الطهي المذهلة...
            كل ما تبحث عنه وأكثر متاح بين يديك الآن.
            استكشف الأقسام بالأسفل.
        </p>

        <div class="aqx-audio-hint">
            🔊 اضغط للاستماع للترحيب
        </div>

        <div class="aqx-pointer">👇</div>

    </div>

</div>

<script>
(() => {

const widget = document.getElementById('aqxWidget');

let isSpeaking = false;

/* Ripple Effect */
function createRipple(e){

    const circle = document.createElement('span');

    const diameter = Math.max(
        widget.clientWidth,
        widget.clientHeight
    );

    const radius = diameter / 2;

    circle.style.width =
    circle.style.height =
    `${diameter}px`;

    const rect = widget.getBoundingClientRect();

    circle.style.left =
    `${e.clientX - rect.left - radius}px`;

    circle.style.top =
    `${e.clientY - rect.top - radius}px`;

    circle.classList.add('aqx-ripple');

    const ripple = widget.querySelector('.aqx-ripple');

    if(ripple){
        ripple.remove();
    }

    widget.appendChild(circle);
}

/* تنظيف النص من الرموز الغريبة */
function cleanArabicText(text){

    return text
    .replace(/[#*_+=~^%$@!<>|\\/[\]{}()0-9]/g,'')
    .replace(/\s+/g,' ')
    .trim();
}

/* تشغيل الترحيب */
function playGreeting(){

    if(isSpeaking) return;

    if(!('speechSynthesis' in window)){
        return;
    }

    isSpeaking = true;

    window.speechSynthesis.cancel();

    const msg = new SpeechSynthesisUtterance();

    /* نص نظيف بدون هاشتاجات أو أرقام */
    msg.text = cleanArabicText(
    'أهلاً بك في أقسام القرماني إكس استكشف عالمنا الآن'
    );

    msg.lang = 'ar-EG';

    msg.rate = 0.88;

    msg.pitch = 1.1;

    msg.volume = 1;

    const voices =
    window.speechSynthesis.getVoices();

    /* اختيار أفضل صوت عربي طبيعي */
    const arabicVoice =
    voices.find(v =>
        v.lang.includes('ar') &&
        !v.name.toLowerCase().includes('english')
    );

    if(arabicVoice){
        msg.voice = arabicVoice;
    }

    msg.onend = () => {
        isSpeaking = false;
    };

    msg.onerror = () => {
        isSpeaking = false;
    };

    window.speechSynthesis.speak(msg);
}

/* الضغط */
widget.addEventListener('click', e => {
    createRipple(e);
    playGreeting();
});

})();
</script>
